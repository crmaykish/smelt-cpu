// add_test.hex
0000    // NOP
0000    // NOP

// Add with no carry, no zero
1000    // LDI R0 2222
2222
1100    // LDI R1 3333
3333
3020    // ADD R0 R1

// Add with zero
1000    // LDI R0 0000
0000
3000    // ADD R0 R0

// Add with carry
1000    // LDI R0 F000
F000
1100    // LDI R1 2000
2000
3020    // ADD R0 R1

0800    // HALT
