// mem_test.hex

// R6 = output port; smoke-test the port with a direct constant first
1600    // 0x00  LDI R6
FFFF    // 0x01    imm   (port address)
1000    // 0x02  LDI R0
F00D    // 0x03    imm
2E00    // 0x04  ST [R6], R0      -> OUT: f00d   (port works before any RAM)

// set up two (address, value) pairs
1200    // 0x05  LDI R2
0040    // 0x06    imm   (addr1)
1300    // 0x07  LDI R3
BEEF    // 0x08    imm   (data1)
1400    // 0x09  LDI R4
0080    // 0x0A    imm   (addr2)
1500    // 0x0B  LDI R5
CAFE    // 0x0C    imm   (data2)

// store both, then load both back into observable registers
2A60    // 0x0D  ST [R2], R3      mem[0040] = BEEF
2CA0    // 0x0E  ST [R4], R5      mem[0080] = CAFE
2040    // 0x0F  LD R0, [R2]      R0 = mem[0040]  (expect BEEF)
2180    // 0x10  LD R1, [R4]      R1 = mem[0080]  (expect CAFE; proves no aliasing)

// echo the round-tripped values out the port
2E00    // 0x11  ST [R6], R0      -> OUT: beef
2E20    // 0x12  ST [R6], R1      -> OUT: cafe

// done marker out the port, then stop
1700    // 0x13  LDI R7
EEEE    // 0x14    imm
2EE0    // 0x15  ST [R6], R7      -> OUT: eeee
0800    // 0x16  HALT
