// Opcode Definitions
localparam NOP  = 16'h00;
localparam HALT = 16'h01;
localparam LDI  = 16'h02;
localparam MOV  = 16'h03;
localparam ADD  = 16'h06;
localparam SUB  = 16'h07;
localparam AND  = 16'h08;
localparam OR   = 16'h09;
localparam XOR  = 16'h0A;
localparam SHL  = 16'h0B;
localparam SHR  = 16'h0C;
localparam CMP  = 16'h0D;
